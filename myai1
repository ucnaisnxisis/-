            }
            if (!response) {
                response = rules.find(rule => rule[0].toString() === '/.*/i')[1];
            }
            setTimeout(() => appendMessage(response, 'bot'), 200);
        },
        addRule: (pattern, response) => { rules.unshift([pattern, response]); },
        setForceLang: (lang) => { /* Nu face nimic, nu este necesar */ }
    };

