// @match        https://www.dogpile.com/serp?qc=video&q=*&sc=ULxcfvwzcazZ20
// @match        https://www.dogpile.com/serp?qc=news&q=*&sc=giInZcYVPfxR20
// @icon         https://www.google.com/s2/favicons?sz=64&domain=bing.com
// @grant        none
// @run-at       document-start
// ==/UserScript==

(function () {
  'use strict';

  // --- small helpers
  const nowHref = () => window.location.href;
  const isHTTPS = () => location.protocol === 'https:';
  const sameOriginDomainValid = (candidate) => {
    // only allow if candidate equals current origin's hostSuffix (e.g., "bing.com")
    if (!candidate) return false;
    const hostParts = window.location.hostname.split('.');
    const hostSuffix = hostParts.slice(-2).join('.');
    return candidate === hostSuffix || candidate === window.location.hostname;
  };

  // --- safe default URL param append (only if not present)
  (function ensureUrlSafeOff() {
    try {
      const url = new URL(nowHref());
      // only add param if same-origin (we're already on that site) and param absent
      if (!url.searchParams.has('safe')) {
        url.searchParams.set('safe', 'off');
        // avoid changing origin; this is same page with param updated
        history.replaceState(null, '', url.toString());
      } else if (url.searchParams.get('safe') !== 'off') {
        url.searchParams.set('safe', 'off');
        history.replaceState(null, '', url.toString());
      }
    } catch (e) {
      // ignore URL parse errors
    }
  })();

  // --- settings per site (only keys used on current hostname evaluated)
  const cookieSettings = {
    bing: {
      cookie: 'SRCHHPGUSR',
      is_array: true,
      name: 'ADLT',
      value: 'OFF',
      domain: null, // use null to omit domain attribute (safer)
      sameSite: 'None',
      separator: '&',
      session: false
    },
    duckduckgo: {
      cookie: 'p',
      is_array: false,
      value: '-2',
      domain: null,
      sameSite: 'Lax'
    },
    yep: {
      localStorage: 'safeSearch',
      value: 'off',
      replaceUrl: 'safeSearch'
    },
    yahoo: {
      cookie: 'sB',
      is_array: true,
      name: 'vm',
      value: 'p',
      domain: null,
      sameSite: 'None',
      session: true,
      separator: '&'
    },
    you: {
      cookie: 'safesearch_guest',
      is_array: false,
      value: 'Off',
      domain: null
    },
    ecosia: {
      cookie: 'ECFG',
      is_array: true,
      name: 'f',
      value: 'n',
      domain: null,
      separator: ':',
      sameSite: 'Lax'
    },
    qwant: {
      cookie: 's',
      is_array: false,
      value: '0',
      domain: null,
      replaceUrl: 's'
    },
    metager: {
      cookie: 'web_setting_s',
      is_array: false,
      value: 'o',
      domain: null,
      replaceUrl: 's'
    },
    startpage: {
      cookie: 'preferences',
      is_array: true,
      name: 'disable_family_filter',
      value: '1',
      separator: 'N',
      equal: 'EEE',
      domain: null
    },
    brave: {
      cookie: 'safesearch',
      is_array: false,
      value: 'off',
      domain: null
    }
  };

  // derive website key from hostname (second-level label if possible)
  let website = (function () {
    try {
      const parts = window.location.hostname.split('.');
      // prefer known host mapping for hosts like search.brave.com
      const known = {
        'search': parts.slice(-2).join('.')
      };
      // simple approach: take second-to-last label when hostname has at least 2 parts
      return parts.length >= 2 ? parts.at(-2) : window.location.hostname;
    } catch (e) {
      return window.location.hostname;
    }
  })();

  // fallback: special-case some hosts
  if (window.location.hostname.includes('search.brave.com')) website = 'brave';
  if (window.location.hostname.includes('duckduckgo.com')) website = 'duckduckgo';
  if (window.location.hostname.includes('yep.com')) website = 'yep';
  if (window.location.hostname.includes('startpage.com')) website = 'startpage';

  const settings = cookieSettings[website];
  if (!settings) {
    // nothing configured for this host
    return;
  }

  // --- cookie / storage operations with cross-origin safety
  function getRawCookies() {
    try { return document.cookie || ''; } catch (e) { return ''; }
  }

  function buildArrayCookieString(rawCookie, cfg) {
    const sep = cfg.separator || '&';
    const eq = cfg.equal || '=';
    // remove spaces/semicolons around cookie value
    let base = rawCookie ? rawCookie.replaceAll(/[ ;]/g, '') : (cfg.cookie + '=');
    // ensure cookie contains name=...
    if (base.includes(cfg.name + eq)) {
      // replace existing name=... with desired value if different
      const re = new RegExp('(^|'+escapeRegExp(sep)+')'+escapeRegExp(cfg.name)+eq+'[^'+escapeRegExp(sep)+']*');
      if (!new RegExp(escapeRegExp(cfg.name)+eq+escapeRegExp(cfg.value)).test(base)) {
        base = base.replace(re, '$1' + cfg.name + eq + cfg.value);
      } else {
        // already correct
      }
    } else {
      // append name=value
      if (!base.endsWith(sep) && base.length) base += sep;
      base += cfg.name + eq + cfg.value;
    }
    return base;
  }

  function buildSimpleCookieString(cfg) {
    return cfg.cookie + '=' + cfg.value;
  }

  function escapeRegExp(string) {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  // actual setter: only include domain attribute when it's explicitly allowed AND valid for current origin
  function setCookieString(cookieString, cfg) {
    try {
      let cookieParts = cookieString + '; path=/;';
      if (!cfg.session) {
        cookieParts += ' expires=Fri, 01 Jan 2038 00:00:00 GMT;';
      }
      if (cfg.domain) {
        // validate candidate domain before adding
        if (sameOriginDomainValid(cfg.domain)) {
          cookieParts += ' domain=' + cfg.domain + ';';
        } else {
          // skip domain attribute to avoid cross-origin set attempt
        }
      }
      // only add Secure if current protocol is https
      if (isHTTPS()) cookieParts += ' Secure;';
      if (cfg.sameSite) {
        // some browsers reject SameSite=None without Secure, so require https for None
        if (cfg.sameSite.toLowerCase() === 'none') {
          if (isHTTPS()) cookieParts += ' SameSite=None;';
        } else {
          cookieParts += ' SameSite=' + cfg.sameSite + ';';
        }
      }
      document.cookie = cookieParts;
      console.log('[disable-safesearch] set cookie:', cookieParts.split(';')[0]);
    } catch (e) {
      console.warn('[disable-safesearch] cookie set failed', e);
    }
  }

  // small delay to increase chance cookie persists if site scripts overwrite
  const POSTSET_DELAY = 75;

  function applySettings() {
    try {
      if (settings.localStorage) {
        try {
          localStorage.setItem(settings.localStorage, settings.value);
          console.log('[disable-safesearch] localStorage set:', settings.localStorage, settings.value);
          // remove URL replace param if present
          if (settings.replaceUrl) {
            const loc = window.location.toString().replace(new RegExp('([?&])' + escapeRegExp(settings.replaceUrl) + '[^&]*&?'), '$1');
            if (loc !== window.location.toString()) window.location = loc;
          } else {
            setTimeout(() => location.reload(), POSTSET_DELAY);
          }
          return;
        } catch (e) {
          // ignore localStorage errors
        }
      }

      if (settings.cookie) {
        // read current cookie
        const raw = getRawCookies();
        // find cookie entry if exists
        const cookieMatch = raw.match(new RegExp('(?:^|; )' + escapeRegExp(settings.cookie) + '=[^;]*'));
        let newCookie;
        if (settings.is_array) {
          const matched = cookieMatch ? cookieMatch[0].replaceAll(/[ ;]/g, '') : (settings.cookie + '=');
          newCookie = buildArrayCookieString(matched, settings);
        } else {
          const existing = cookieMatch ? cookieMatch[0].replaceAll(/[ ;]/g, '') : '';
          if (existing !== (settings.cookie + '=' + settings.value)) {
            newCookie = buildSimpleCookieString(settings);
          } else {
            // already correct
            newCookie = null;
          }
        }

        if (newCookie) {
          // set after tiny timeout to reduce race with site scripts
          setTimeout(() => setCookieString(newCookie, settings), POSTSET_DELAY);
          // then reload or remove replaceUrl param if provided
          setTimeout(() => {
            if (settings.replaceUrl && window.location.toString().match(new RegExp('([?&])' + escapeRegExp(settings.replaceUrl) + '[^&]*&?'))) {
              window.location = window.location.toString().replace(new RegExp('([?&])' + escapeRegExp(settings.replaceUrl) + '[^&]*&?'), '$1');
            } else {
              // reload only if navigation type is not reload
              const nav = performance.getEntriesByType('navigation')[0];
              if (!nav || nav.type !== 'reload') location.reload();
            }
          }, POSTSET_DELAY + 20);
        } else {
          // nothing to do, but clean URL param if requested
          if (settings.replaceUrl && window.location.toString().match(new RegExp('([?&])' + escapeRegExp(settings.replaceUrl) + '[^&]*&?'))) {
            window.location = window.location.toString().replace(new RegExp('([?&])' + escapeRegExp(settings.replaceUrl) + '[^&]*&?'), '$1');
          } else {
            console.log('[disable-safesearch] nothing to do for', website);
          }
        }
      }
    } catch (e) {
      console.error('[disable-safesearch] applySettings error', e);
    }
  }

  // run
  applySettings();

})();
