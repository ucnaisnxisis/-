            position: absolute;
            z-index: 1000000;
            bottom: 60px;
            right: 20px;
            max-width: 300px;
        }
        .lcb-emoji-option {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            padding: 4px;
            border-radius: 4px;
        }
        .lcb-emoji-option:hover {
            background: rgba(0, 0, 0, 0.06);
        }
        @media (max-width: 420px) {
            #local-chat-bot .lcb-window {
                right: 10px;
