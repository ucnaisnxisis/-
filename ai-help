// ==UserScript==
// @name         Reject Cookies (robust)
// @namespace    http://tampermonkey.net/
// @version      0.2
// @description  Click common "reject" buttons with improved robustness and logging
// @match        *://*/*
// @match        https://m.youtube.com/; https://yahoo.com/
// @run-at       document-idle
// @grant        none
// ==/UserScript==

(function() {
  'use strict';

  const DEBUG = true;
  const DRY_RUN = true;

  function log(...a){ if (DEBUG) console.log('[reject]', ...a); }
  function warn(...a){ if (DEBUG) console.warn('[reject]', ...a); }
  function err(...a){ if (DEBUG) console.error('[reject]', ...a); }

  const rejectTexts = [
    'respinge folosirea cookies in scopurile descrise',
    'respinge folosirea cookies în scopurile descrise',
    'respinge folosirea cookie-urilor in scopurile descrise',
    'respinge modulele cookies optionale',
    'respinge modulele cookies',
    'respinge tot',
    'nu multumesc',
    'accept only essential cookies',
    'only essential',
    'essential only',
    'reject all',
    'decline',
    'deny',
    'INTRĂ - Am peste 18 ani sau mai mult',
    'INTRĂ - Am peste 18 ani',
    '18+',
    'nu multumesc!',
    'nu ma abonez',
    'da, am peste 18 ani',
    'am 18+ ani',
    '18+',
    'respinge modulele cookies optionale',
    'respinge modulele cookies',
    'respinge tot',
    'i am 18 or older - enter',
    'intră - am 18 ani sau mai mult',
    'i am 18+',
    'i am 18',
    'over18_enter',
    'accept only essential cookies'
  ].map(s => s.toLowerCase());

  function normalize(s){
    try {
      return (s || '')
        .toString()
        .toLowerCase()
        .replace(/\s+/g, ' ')
        .trim();
    } catch(e){
      return '';
    }
  }

  function elementTextCandidates(el){
    if(!el) return [];

    const out = [];

    try {
      out.push(el.innerText, el.textContent);

      if (el.getAttribute){
        out.push(el.getAttribute('aria-label'));
        out.push(el.getAttribute('title'));
        out.push(el.getAttribute('value'));
        out.push(el.getAttribute('data-testid'));
      }
    } catch(e){}

    return out.filter(Boolean).map(normalize);
  }

  function isStrictlyVisible(el){
    if (!el || !el.getBoundingClientRect) return false;

    try {
      const rect = el.getBoundingClientRect();

      if (rect.width < 8 || rect.height < 8) return false;

      const style = window.getComputedStyle
        ? window.getComputedStyle(el)
        : {};

      if (
        style &&
        (
          style.display === 'none' ||
          style.visibility === 'hidden' ||
          parseFloat(style.opacity) === 0
        )
      ) return false;

      if (style.pointerEvents === 'none') return false;

      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;

      const inViewport =
        cx >= 0 &&
        cy >= 0 &&
        cx <= window.innerWidth &&
        cy <= window.innerHeight;

      if (!inViewport) return false;

      const topEl = document.elementFromPoint(
        Math.min(Math.max(0, cx), window.innerWidth - 1),
        Math.min(Math.max(0, cy), window.innerHeight - 1)
      );

      if (!topEl) return false;

      return el.contains(topEl) || topEl.contains(el);

    } catch(e){
      return false;
    }
  }

  const rejectPatterns = [
    /\b(respinge|refuz|decline|deny|reject|essential only|only essential)\b/i
  ];

  function looksLikeRejectButton(el){
    if (!el) return false;

    try {
      const tag = (el.tagName || '').toLowerCase();
      const role = el.getAttribute?.('role') || '';

      if (
        !(
          tag === 'button' ||
          tag === 'a' ||
          tag === 'input' ||
          role === 'button'
        )
      ){
        return false;
      }

      const href = el.getAttribute?.('href');

      if (
        href &&
        /^https?:\/\//i.test(href) &&
        !rejectPatterns.some(rx =>
          rx.test(elementTextCandidates(el).join(' '))
        )
      ){
        return false;
      }

      const texts = elementTextCandidates(el).join(' ');

      for (const rx of rejectPatterns){
        if (rx.test(texts)) return true;
      }

    } catch(e){}

    return false;
  }

  function wait(ms){
    return new Promise(res => setTimeout(res, ms));
  }

  function simulatePointerClick(el){
    try{
      const opts = {
        bubbles: true,
        cancelable: true,
        view: window
      };

      el.dispatchEvent(new PointerEvent('pointerdown', opts));
      el.dispatchEvent(new MouseEvent('mousedown', opts));
      el.dispatchEvent(new PointerEvent('pointerup', opts));
      el.dispatchEvent(new MouseEvent('mouseup', opts));
      el.dispatchEvent(new MouseEvent('click', opts));

      return true;

    } catch(e){
      return false;
    }
  }

  async function clickElementSafe(el){
    if (!el) return false;

    try {

      try {
        el.scrollIntoView({
          block: 'center',
          inline: 'center',
          behavior: 'auto'
        });
      } catch(e){}

      await wait(120);

      try {
        el.focus?.();
      } catch(e){}

      if (simulatePointerClick(el)) return true;

      try {
        el.click?.();
        return true;
      } catch(e){}

    } catch(e){
      err('clickElementSafe error', e);
    }

    return false;
  }

  async function cautiousClick(el){
    if (!el) return false;

    try {

      await wait(400);

      if (!isStrictlyVisible(el)) {
        log('Element not visible anymore');
        return false;
      }

      if (DRY_RUN) {
        log('DRY RUN would click:', elementTextCandidates(el));
        return true;
      }

      return await clickElementSafe(el);

    } catch(e){
      err('cautiousClick error', e);
      return false;
    }
  }

  const tried = new Set();

  async function tryRejectOnce(){

    const elements = Array.from(
      document.querySelectorAll(
        'button, a, input, [role="button"]'
      )
    );

    for (const el of elements){

      const signature =
        el.tagName +
        '|' +
        (el.id || '') +
        '|' +
        normalize(el.innerText || '');

      if (tried.has(signature)) continue;

      tried.add(signature);

      if (!isStrictlyVisible(el)) continue;

      if (!looksLikeRejectButton(el)) continue;

      log('Found reject candidate:', elementTextCandidates(el));

      const ok = await cautiousClick(el);

      if (ok){
        log('Clicked');
        return true;
      }
    }

    return false;
  }

  let attempts = 0;
  const maxAttempts = 8;

  async function tryLoop(){

    if (attempts >= maxAttempts) return;

    attempts++;

    const ok = await tryRejectOnce();

    if (ok){
      observer.disconnect();
      return;
    }

    setTimeout(
      tryLoop,
      1200 + attempts * 800
    );
  }

  const observer = new MutationObserver(() => {
    tryLoop();
  });

  observer.observe(
    document.documentElement || document.body,
    {
      childList: true,
      subtree: true
    }
  );

  tryLoop();

})();
