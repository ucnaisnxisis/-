            }
        }
    `);

    // --- Element Refs ---
    const bodyDiv = document.getElementById('lcb-body');
    const form = document.getElementById('lcb-form');
    const input = document.getElementById('lcb-input');
    const minBtn = document.getElementById('lcb-minimize-btn');
    const lcbWindow = document.getElementById('lcb-window');
    const lcbHeader = document.getElementById('lcb-header');
    const resizeHandle = document.getElementById('lcb-resize-handle');
    const emojiBtn = document.querySelector('.lcb-emoji-btn');

    // --- Floating Color Panel Refs ---
    const floatingPalette = document.getElementById('lcb-floating-palette');
    const saveFloatingColorsBtn = document.getElementById('lcb-save-floating-colors');
    const closeFloatingPanelBtn = document.getElementById('lcb-close-floating-panel');

    // --- Drag & Drop and Resize Logic ---
    lcbHeader.addEventListener('mousedown', (e) => {
        if (e.target.classList.contains('lcb-minimize') || e.target.classList.contains('lcb-emoji-btn')) return;

        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
        const rect = lcbWindow.getBoundingClientRect();
        const windowX = window.innerWidth - rect.right;
        const windowY = window.innerHeight - rect.bottom;
        const offsetX = startX - rect.left;
        const offsetY = startY - rect.top;

        function moveWindow(e) {
            if (!isDragging) return;
            e.preventDefault();
            position.x = window.innerWidth - e.clientX - offsetX;
            position.y = window.innerHeight - e.clientY - offsetY;
            lcbWindow.style.right = `${position.x}px`;
            lcbWindow.style.bottom = `${position.y}px`;
        }

        function stopDrag() {
            isDragging = false;
            document.removeEventListener('mousemove', moveWindow);
            document.removeEventListener('mouseup', stopDrag);
            saveSettings();
        }

        document.addEventListener('mousemove', moveWindow);
        document.addEventListener('mouseup', stopDrag);
    });

    resizeHandle.addEventListener('mousedown', (e) => {
        e.stopPropagation();
        isResizing = true;
        startX = e.clientX;
        startY = e.clientY;
        startWidth = parseInt(lcbWindow.style.width || size.width);
        startHeight = parseInt(lcbWindow.style.height || size.height);

        function resizeWindow(e) {
            if (!isResizing) return;
            e.preventDefault();
            const newWidth = startWidth + (e.clientX - startX);
            const newHeight = startHeight + (e.clientY - startY);

            size.width = `${Math.max(newWidth, 200)}px`;
            size.height = `${Math.max(newHeight, 200)}px`;
            lcbWindow.style.width = size.width;
            lcbWindow.style.height = size.height;
        }

        function stopResize() {
            isResizing = false;
            document.removeEventListener('mousemove', resizeWindow);
            document.removeEventListener('mouseup', stopResize);
            saveSettings();
        }

        document.addEventListener('mousemove', resizeWindow);
        document.addEventListener('mouseup', stopResize);
    });

    // --- Message Utilities ---
    function appendMessage(text, who = 'bot') {
        if (!text) return null;
        const el = document.createElement('div');
        el.className = 'lcb-msg ' + (who === 'user' ? 'lcb-user' : 'lcb-bot');

        if (who === 'bot') {
            const img = document.createElement('img');
            img.src = 'https://assets.mycast.io/actor_images/actor-lucy-elfen-lied-1121936_large.jpg';
            img.className = 'lcb-bot-img';
            img.alt = 'Lucy';
            el.appendChild(img);

            const nameSpan = document.createElement('span');
            nameSpan.className = 'lcb-bot-name';
            nameSpan.textContent = 'Lucy: ';
            el.appendChild(nameSpan);
        }

        const textSpan = document.createElement('span');
        textSpan.innerHTML = text.includes('<') ? text : escapeHtml(text);
        el.appendChild(textSpan);

        bodyDiv.appendChild(el);
        bodyDiv.scrollTop = bodyDiv.scrollHeight;
        return el;
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function clearAllMessages() {
        bodyDiv.innerHTML = '';
        appendMessage('🧹 Toate mesajele au fost șterse.', 'bot');
    }

    // --- Emoji Picker ---
    function showEmojiPicker() {
        const emojiPicker = document.createElement('div');
        emojiPicker.className = 'lcb-emoji-picker';
        emojiPicker.innerHTML = `
            <button class="lcb-emoji-option" data-emoji="😊">😊</button>
            <button class="lcb-emoji-option" data-emoji="😍">😍</button>
            <button class="lcb-emoji-option" data-emoji="😂">😂</button>
            <button class="lcb-emoji-option" data-emoji="😢">😢</button>
            <button class="lcb-emoji-option" data-emoji="👍">👍</button>
            <button class="lcb-emoji-option" data-emoji="❤️">❤️</button>
            <button class="lcb-emoji-option" data-emoji="🎉">🎉</button>
            <button class="lcb-emoji-option" data-emoji="😎">😎</button>
            <button class="lcb-emoji-option" data-emoji="🤔">🤔</button>
            <button class="lcb-emoji-option" data-emoji="🙏">🙏</button>
            <button class="lcb-emoji-option" data-emoji="😘">😘</button>
            <button class="lcb-emoji-option" data-emoji="😇">😇</button>
            <button class="lcb-emoji-option" data-emoji="💪">💪</button>
            <button class="lcb-emoji-option" data-emoji="👀">👀</button>
            <button class="lcb-emoji-option" data-emoji="🌟">🌟</button>
            <button class="lcb-emoji-option" data-emoji="🔥">🔥</button>
        `;
        document.body.appendChild(emojiPicker);

        emojiPicker.querySelectorAll('.lcb-emoji-option').forEach(btn => {
            btn.addEventListener('click', () => {
                const emoji = btn.getAttribute('data-emoji');
                input.value += emoji;
                input.focus();
                emojiPicker.remove();
            });
        });

        document.addEventListener('click', (e) => {
            if (!emojiPicker.contains(e.target) && e.target !== emojiBtn) {
                emojiPicker.remove();
            }
        }, { once: true });
    }

    // --- Floating Color Panel Functions ---
    function populateFloatingColorPanel() {
        floatingPalette.innerHTML = `
            <div style="display: flex; flex-direction: column; gap: 8px;">
                ${Object.keys(colors).map(key => `
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <label style="width: 120px; font-size: 12px;">${key}:</label>
                        <input type="text" id="floating-color-${key}" class="lcb-color" placeholder="#hex" value="${colors[key] || ''}" style="flex: 1; padding: 6px; border: 1px solid #ccc; border-radius: 4px;" />
                    </div>
                `).join('')}
            </div>
        `;
    }

    function applySettingsToUI() {
        colors = Object.assign({}, colorDefaults, colors);
        const prev = document.querySelector('style[data-lcb-injected]');
        if (prev) prev.remove();
        const css = `
            #local-chat-bot .lcb-window { background: ${colors.windowBg} !important; }
            .lcb-header { background: linear-gradient(90deg, ${colors.headerGradientFrom}, ${colors.headerGradientTo}) !important; }
            .lcb-body { background: ${colors.bodyBg} !important; }
            .lcb-bot { background: ${colors.botBg} !important; color: ${colors.botText} !important; }
            .lcb-user { background: ${colors.userBg} !important; color: ${colors.userText} !important; }
            .lcb-send, .lcb-window.minimized .lcb-minimize, .lcb-resize-handle { background: ${colors.accent} !important; }
            .lcb-bot-name { color: ${colors.botNameColor} !important; }
        `;
        const s = document.createElement('style');
        s.setAttribute('data-lcb-injected', '1');
        s.textContent = css;
        document.head.appendChild(s);
        document.getElementById('lcb-title').style.color = colors.botNameColor;
    }

    function isValidHex(h) {
        return /^#([0-9A-F]{3}){1,2}$/i.test(h);
    }

    // --- Event Listeners ---
    form.addEventListener('submit', (e) => {
        e.preventDefault();
        const raw = (input.value || '').trim();
        if (!raw) return;
        const lower = raw.toLowerCase();

        // q1 toggle (fără notificare)
        if (lower === 'q1') {
            q1Mode = !q1Mode;
            input.value = '';
            input.focus();
            return;
        }

        // qq handling
        if (lower.startsWith('qq ')) {
            const payload = raw.slice(3).trim();
            appendMessage(payload, 'bot');
            input.value = '';
            input.focus();
            return;
        }

        // Clear messages
        const clearCommands = ['sterge mesaje', 'șterge mesaje', 'sterge-chat', 'sterge chat', 'clear messages', 'clear','șterge mesajele','sterge mesajele'];
        if (clearCommands.includes(lower)) {
            appendMessage(raw, 'user');
            clearAllMessages();
            input.value = '';
            input.focus();
            return;
        }

        // Colors command
        if (lower === 'culori') {
            appendMessage(raw, 'user');
            populateFloatingColorPanel();
            floatingColorPanel.style.display = 'block';
            input.value = '';
            input.focus();
            return;
        }

        // Normal flow
        appendMessage(raw, 'user');
        if (!q1Mode) {
            const reply = getResponse(raw);
            if (reply) {
                setTimeout(() => {
                    appendMessage(reply, 'bot');
                }, 250);
            }
        }
        input.value = '';
        input.focus();
    });

    emojiBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        showEmojiPicker();
    });

    minBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isMin = lcbWindow.classList.contains('minimized');
        if (isMin) {
            lcbWindow.classList.remove('minimized');
            minBtn.textContent = '—';
            input.focus();
        } else {
            lcbWindow.classList.add('minimized');
            minBtn.textContent = '+';
        }
    });

    lcbHeader.addEventListener('dblclick', () => {
        lcbWindow.classList.toggle('minimized');
    });

    lcbWindow.addEventListener('click', (e) => {
        if (lcbWindow.classList.contains('minimized')) {
            lcbWindow.classList.remove('minimized');
            input.focus();
        }
    });

    // Floating color panel events
    closeFloatingPanelBtn.addEventListener('click', () => {
        floatingColorPanel.style.display = 'none';
    });

    saveFloatingColorsBtn.addEventListener('click', () => {
        let allValid = true;
        Object.keys(colors).forEach(key => {
            const inputEl = document.getElementById(`floating-color-${key}`);
            const value = inputEl.value.trim();
            if (value && !isValidHex(value)) {
                allValid = false;
                inputEl.style.border = '1px solid red';
            } else {
                inputEl.style.border = '';
                if (value) colors[key] = value;
            }
        });
        if (!allValid) {
            alert('Unele coduri hex nu sunt valide! Folosește formatul #rrggbb sau #rgb.');
            return;
        }
        saveSettings();
        applySettingsToUI();
        floatingColorPanel.style.display = 'none';
        appendMessage('✅ Culorile au fost salvate!', 'bot');
    });

    // --- Global API ---
    window.localChatBot = {
        send: (text) => {
            appendMessage(text, 'user');
            if (!q1Mode) {
                setTimeout(() => appendMessage(getResponse(text), 'bot'), 200);
            }
        },
        clear: () => { clearAllMessages(); }
    };

    // --- Initialize ---
    applySettingsToUI();
    applySizeToUI();
    input.focus();
    appendMessage('🌸 **Bun venit!** Scrie "ajutor" pentru a vedea comenzi disponibile.', 'bot');
})();
