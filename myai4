        }
        .lcb-window.minimized .lcb-icon,
        .lcb-window.minimized .lcb-title,
        .lcb-window.minimized .lcb-body,
        .lcb-window.minimized .lcb-form,
        .lcb-window.minimized .lcb-resize-handle {
            display: none;
        }
        .lcb-window.minimized .lcb-minimize {
            display: block;
            width: 40px;
            height: 40px;
            border-radius: 50%;
