        // --- Watchlist ---
        [/^(adaugă|pune) (.+) la watchlist/i, (msg, match) => {
            const anime = match[2].trim();
            toggleWatchlist(anime, 'add');
            return `Ai adăugat **${anime}** la watchlist! 📋`;
