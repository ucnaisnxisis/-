        [/^(șterge|elimină) (.+) din watchlist/i, (msg, match) => {
            const anime = match[2].trim();
            toggleWatchlist(anime, 'remove');
            return `Ai șters **${anime}** din watchlist! 🗑️`;
        }],

        // --- Anime Quiz ---
        [/^(.+)/i, (msg, match) => {
            if (currentQuizQuestion) {
                return checkQuizAnswer(match[1]);
