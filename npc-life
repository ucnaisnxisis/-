    function botTick() {
        if (!appState.settings.autoMessagesEnabled) return;

        const bots = appState.users.filter(u => u.isBot && u.online && !u.banned);
        if (bots.length === 0) return;

        const activeTab = document.querySelector('.discussion-tab.active')?.dataset.topic || 'general';
        const messages = sampleTexts[activeTab] || sampleTexts.general;

        bots.forEach(bot => {
            if (Math.random() < 0.3) {
                if (!canPost(bot)) return;

                let text = randomFrom(messages);
                const user = uidToUser(appState, bot.id);

                if (!user.canPostLinks) {
                    text = text.replace(/https?:\/\/\S+/gi, '[Link blocat]');
                }
                if (!user.canPostImages) {
                    text = text.replace(/📷/g, '[Imagine blocată]');
                }

                text = censorMessage(text, appState.settings.bannedWords);

                const msg = {
                    from: bot.id,
                    text: text,
                    time: nowISO(),
                    topic: activeTab !== 'general' ? activeTab : undefined
                };

                if (activeTab === 'general') {
                    appState.messages.push(msg);
                } else {
                    const discussion = appState.activeDiscussions.find(d => d.topic === activeTab);
                    if (discussion) {
                        discussion.messages.push(msg);
                    }
                }

                bot.lastMessageTime = Date.now();
            }
        });

        saveState(appState);
        renderMessages();
    }

    function disconnectSimulateTick() {
        if (!appState.settings.disconnectSimulateEnabled) return;

        const onlineUsers = appState.users.filter(u => u.online && !u.banned && !u.isBot && u.id !== 'you');
        if (onlineUsers.length === 0) return;

        const disconnectDuration = Math.floor(Math.random() * 3) + 3;
        const userToDisconnect = randomFrom(onlineUsers);
        if (userToDisconnect) {
            userToDisconnect.online = false;
            userToDisconnect.pawnColor = colorPalette.offline.hex;
            userToDisconnect.lastSeen = nowISO();

            const disconnectNotification = {
                from: 'system',
                text: `${userToDisconnect.name} s-a deconectat.`,
                time: nowISO()
            };
            appState.messages.push(disconnectNotification);

            saveState(appState);
            renderUsers();
            renderMessages();

            setTimeout(() => {
                userToDisconnect.online = true;
                userToDisconnect.pawnColor = colorPalette[userToDisconnect.role.toLowerCase()]?.hex || colorPalette.member.hex;
                userToDisconnect.lastSeen = nowISO();

                const reconnectNotification = {
                    from: 'system',
                    text: `${userToDisconnect.name} s-a reconectat.`,
                    time: nowISO()
                };
                appState.messages.push(reconnectNotification);

                saveState(appState);
                renderUsers();
                renderMessages();
            }, disconnectDuration * 1000);
        }
    }

